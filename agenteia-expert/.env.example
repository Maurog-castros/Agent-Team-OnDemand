# Copia a .env y completa LLM_API_KEY (nunca commitear .env).

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://agenteia:change-me@postgres:5432/agenteia
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://redis:6379/0
TIMEZONE=America/Santiago
WORKSPACE_ROOT=/app/workspaces

# Desarrollo local sin Docker: usa sqlite y hosts localhost
# DATABASE_URL=sqlite+aiosqlite:///./agenteia.db
# REDIS_URL=redis://localhost:6379/0
# WORKSPACE_ROOT=workspaces

LLM_PROVIDER=custom
LLM_BASE_URL=https://ia.iamiko.cl/v1
LLM_API_KEY=
LLM_REQUEST_TIMEOUT_SECONDS=240
DEFAULT_MODEL=auto-hermes

AGENTEIA_EXPERT_MODEL=auto-hermes
FULLSTACK_MODEL=auto-hermes
DEVOPS_MODEL=auto-hermes
SCRUM_MODEL=auto-hermes
