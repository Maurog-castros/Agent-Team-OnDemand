APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8092
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./data/agenteia-prod.db
REDIS_URL=redis://127.0.0.1:6379/0
TIMEZONE=America/Santiago
WORKSPACE_ROOT=./workspaces

LLM_PROVIDER=custom
LLM_BASE_URL=https://ia.iamiko.cl/v1
LLM_API_KEY=
LLM_REQUEST_TIMEOUT_SECONDS=240
DEFAULT_MODEL=auto-hermes

AGENTEIA_EXPERT_MODEL=auto-hermes
FULLSTACK_MODEL=auto-hermes
DEVOPS_MODEL=auto-hermes
SCRUM_MODEL=auto-hermes
